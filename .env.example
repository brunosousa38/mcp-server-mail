# --- Infomaniak Mail API ---
# Token from https://manager.infomaniak.com/v3/ng/accounts/token/list (scope: workspace:mail)
MAIL_TOKEN=

# --- MCP HTTP layer ---
# Generate a strong random secret: openssl rand -hex 32   (or: make token)
MCP_AUTH_TOKEN=

# Internal listening (do not change unless you know why)
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0

# Comma-separated CORS origin allowlist. Leave empty to disable browser CORS.
# "*" is rejected when NODE_ENV=production.
MCP_ALLOWED_ORIGINS=

# Per-IP global limit (req/min) and per-tool limit on mail_send_email (calls/min)
MCP_RATE_LIMIT_PER_MIN=60
MCP_SEND_RATE_LIMIT_PER_MIN=5

# Number of trusted proxy hops in front of Express
#   WAN / LAN TLS (Caddy in front): 1
#   LAN HTTP (direct port, no proxy): 0
MCP_TRUST_PROXY=1

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─── WAN mode (make up-wan) ───────────────────────────────────────────────────
# Public hostname Caddy will obtain a Let's Encrypt certificate for.
# Ports 80 and 443 must be reachable from the Internet.
MCP_PUBLIC_DOMAIN=mcp.example.com
ACME_EMAIL=ops@example.com

# ─── LAN TLS mode (make up-lan) ──────────────────────────────────────────────
# Hostname or address Caddy listens on. Caddy generates its own local CA.
# Examples:
#   :443             → listens on all interfaces, port 443
#   mcp.local        → requires this hostname to resolve to the server's IP
#   192.168.1.10     → bind to a specific LAN IP (add port: 192.168.1.10:443)
MCP_LAN_HOST=:443
# Host port to publish for HTTPS (mapped to container 443)
LAN_HTTPS_PORT=443

# ─── LAN HTTP mode (make up-lan-http) ────────────────────────────────────────
# Host port to publish for plain HTTP (no TLS, no reverse proxy)
LAN_HTTP_PORT=3000
