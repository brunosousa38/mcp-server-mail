# Copiez ce fichier en .env pour un usage local, ou définissez ces variables
# directement dans les paramètres Netlify (Site settings > Environment variables).
# Les variables d'environnement sont PRIORITAIRES sur config.json si les deux existent.

# Token d'authentification du serveur MCP.
# Le client doit l'envoyer via "Authorization: Bearer <token>" ou "?token=<token>".
# Générez-le avec : openssl rand -hex 32
MCP_AUTH_TOKEN=

# --- IMAP (lecture des emails) ---
# Exemple Infomaniak : mail.infomaniak.com / 993 / ssl
# Exemple OVH        : ssl0.ovh.net / 993 / ssl
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
# ssl | starttls | none
IMAP_ENCRYPTION=ssl

# --- SMTP (envoi des emails) ---
# Exemple Infomaniak : mail.infomaniak.com / 465 / ssl
# Exemple OVH        : ssl0.ovh.net / 465 / ssl
# Si SMTP_USER / SMTP_PASSWORD sont vides, IMAP_USER / IMAP_PASSWORD sont réutilisés.
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
# ssl | starttls | none
SMTP_ENCRYPTION=ssl

# Adresse et nom affichés comme expéditeur.
# Si vides : MAIL_FROM reprend IMAP_USER, MAIL_FROM_NAME reprend la partie locale de MAIL_FROM.
MAIL_FROM=
MAIL_FROM_NAME=
