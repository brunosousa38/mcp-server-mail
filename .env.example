# --- Infomaniak Mail API ---
# Token from https://manager.infomaniak.com/v3/ng/accounts/token/list (scope: workspace:mail)
MAIL_TOKEN=

# --- MCP HTTP layer ---
# Generate a strong random secret: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Internal listening (do not change unless you know why)
MCP_HTTP_PORT=3000
MCP_HTTP_HOST=0.0.0.0

# Comma-separated CORS origin allowlist. Leave empty to disable browser CORS.
# "*" is rejected when NODE_ENV=production.
MCP_ALLOWED_ORIGINS=

# Per-IP global limit (req/min) and per-tool limit on mail_send_email (calls/min)
MCP_RATE_LIMIT_PER_MIN=60
MCP_SEND_RATE_LIMIT_PER_MIN=5

# Number of trusted proxy hops in front of Express (1 = Caddy only)
MCP_TRUST_PROXY=1

# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# --- Caddy / public exposure ---
MCP_PUBLIC_DOMAIN=mcp.example.com
ACME_EMAIL=ops@example.com
